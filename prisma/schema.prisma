// SyncFlow — Prisma schema
// US-001 — Data Model Expansion (EPIC-01)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Shopify Session (required by @shopify/shopify-app-session-storage-prisma)
// ---------------------------------------------------------------------------
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

// ---------------------------------------------------------------------------
// Tenant root — one row per installed Shopify shop
// AC-001: multi-tenant
// ---------------------------------------------------------------------------
model Store {
  id            String    @id @default(cuid())
  tenantId      String    @unique
  shopDomain    String    @unique
  name          String?
  email         String?
  plan          String    @default("free")
  isActive      Boolean   @default(true)
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  connectedStores    ConnectedStore[]
  products           ProductReference[]
  syncJobs           SyncJob[]
  webhookEvents      WebhookEvent[]
  auditLogs          AuditLog[]
  billing            BillingSubscription?
  inventorySnapshots InventorySnapshot[]

  @@index([tenantId])
  @@index([shopDomain])
  @@index([createdAt])
}

// External marketplaces / secondary shops this tenant syncs to
model ConnectedStore {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider    String // shopify | amazon | etsy | woocommerce ...
  externalId  String
  shopDomain  String?
  accessToken String // encrypted at the application layer
  scopes      String?
  status      String   @default("active") // active | paused | disconnected
  metadata    Json?
  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventoryMappings InventoryMapping[]

  @@unique([storeId, provider, externalId])
  @@index([storeId])
  @@index([provider])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Catalog references (we don't duplicate Shopify data, we reference it)
// ---------------------------------------------------------------------------
model ProductReference {
  id               String   @id @default(cuid())
  storeId          String
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shopifyProductId String
  title            String?
  handle           String?
  status           String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  variants VariantReference[]

  @@unique([storeId, shopifyProductId])
  @@index([storeId])
  @@index([shopifyProductId])
}

model VariantReference {
  id               String           @id @default(cuid())
  productId        String
  product          ProductReference @relation(fields: [productId], references: [id], onDelete: Cascade)
  shopifyVariantId String
  sku              String?
  title            String?
  price            Decimal?
  inventoryItemId  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  inventoryMappings InventoryMapping[]
  snapshots         InventorySnapshot[]

  @@unique([productId, shopifyVariantId])
  @@index([sku])
  @@index([shopifyVariantId])
}

// AC-002: SKU and variant-level mapping
model InventoryMapping {
  id                String           @id @default(cuid())
  variantId         String
  variant           VariantReference @relation(fields: [variantId], references: [id], onDelete: Cascade)
  connectedStoreId  String
  connectedStore    ConnectedStore   @relation(fields: [connectedStoreId], references: [id], onDelete: Cascade)
  externalVariantId String?
  externalSku       String?
  syncStatus        String           @default("pending") // pending | synced | error
  lastSyncedAt      DateTime?
  quantity          Int              @default(0)
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([variantId, connectedStoreId])
  @@index([variantId])
  @@index([connectedStoreId])
  @@index([externalSku])
  @@index([syncStatus])
}

// ---------------------------------------------------------------------------
// Sync engine
// AC-003: queued | processing | completed | failed | dead_letter
// ---------------------------------------------------------------------------
model SyncJob {
  id          String    @id @default(cuid())
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  type        String // e.g. inventory.update, product.sync
  status      String    @default("queued")
  priority    Int       @default(0)
  payload     Json
  result      Json?
  error       String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  scheduledAt DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  logs    SyncLog[]
  retries RetryQueue[]

  @@index([storeId])
  @@index([status])
  @@index([type])
  @@index([scheduledAt])
  @@index([createdAt])
}

model SyncLog {
  id        String   @id @default(cuid())
  syncJobId String
  syncJob   SyncJob  @relation(fields: [syncJobId], references: [id], onDelete: Cascade)
  level     String // info | warn | error
  message   String
  context   Json?
  createdAt DateTime @default(now())

  @@index([syncJobId])
  @@index([level])
  @@index([createdAt])
}

// AC-004: Webhook idempotency (eventId unique = de-dupe)
model WebhookEvent {
  id          String    @id @default(cuid())
  storeId     String?
  store       Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  eventId     String    @unique // X-Shopify-Webhook-Id
  topic       String
  shopDomain  String
  payload     Json
  status      String    @default("received") // received | processed | failed
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@index([storeId])
  @@index([topic])
  @@index([shopDomain])
  @@index([status])
  @@index([createdAt])
}

model RetryQueue {
  id            String   @id @default(cuid())
  syncJobId     String
  syncJob       SyncJob  @relation(fields: [syncJobId], references: [id], onDelete: Cascade)
  attempt       Int
  nextAttemptAt DateTime
  reason        String?
  status        String   @default("pending") // pending | retried | dead_letter
  createdAt     DateTime @default(now())

  @@index([syncJobId])
  @@index([nextAttemptAt])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Billing & governance
// ---------------------------------------------------------------------------
model BillingSubscription {
  id               String    @id @default(cuid())
  storeId          String    @unique
  store            Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  plan             String // free | starter | growth | enterprise
  status           String    @default("active") // active | trialing | past_due | canceled
  shopifyChargeId  String?
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  canceledAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([plan])
}

// AC-005: track sensitive system actions
model AuditLog {
  id        String   @id @default(cuid())
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  actorId   String?
  actorType String? // user | system | webhook
  action    String // store.connected | sync.triggered | billing.updated ...
  resource  String?
  context   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([storeId])
  @@index([action])
  @@index([createdAt])
}

model InventorySnapshot {
  id        String           @id @default(cuid())
  storeId   String
  store     Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variantId String
  variant   VariantReference @relation(fields: [variantId], references: [id], onDelete: Cascade)
  sku       String?
  quantity  Int
  source    String? // shopify | connected | manual
  takenAt   DateTime         @default(now())

  @@index([storeId])
  @@index([variantId])
  @@index([sku])
  @@index([takenAt])
}
